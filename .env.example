# ── Base de données ──────────────────────────────────────────────────────────
# Local :
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sparepart
# Neon (Vercel) — récupérer dans Vercel > Storage > Neon > Connect :
# DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production :
# NEXT_PUBLIC_SITE_URL=https://ton-domaine.vercel.app

# ── Pipeline d'ingestion Ollama ───────────────────────────────────────────────
# Clé secrète protégeant l'endpoint POST /api/ingest.
# Génère avec : openssl rand -hex 32
INGEST_API_KEY=remplace_par_une_cle_secrete

# ── API publique payante (Stripe) ─────────────────────────────────────────────
# Récupérer dans https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Récupérer après avoir créé le webhook dans Stripe → Developers → Webhooks
# Événements à écouter : checkout.session.completed, customer.subscription.*,
#   invoice.payment_failed, invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs des prix récurrents créés dans Stripe Dashboard → Products
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# Facturation à l'usage (dépassement de quota) :
# 1. Stripe → Billing → Meters → créer un meter avec event_name "api_requests_overage"
#    (agrégation : somme, payload value : "value", customer : "stripe_customer_id")
# 2. Créer un prix récurrent "metered" lié à ce meter (ex : 0,001 €/unité = 1 €/1 000 req)
STRIPE_PRICE_OVERAGE=price_...
# Secret du cron Vercel qui rapporte l'usage à Stripe (vercel.json → /api/cron/report-usage)
# Vercel envoie automatiquement "Authorization: Bearer $CRON_SECRET" si la variable existe.
# Génère avec : openssl rand -hex 32
CRON_SECRET=remplace_par_une_cle_secrete

# ── Base de données ──────────────────────────────────────────────────────────
# Local :
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sparepart
# Neon (Vercel) — récupérer dans Vercel > Storage > Neon > Connect :
# DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production :
# NEXT_PUBLIC_SITE_URL=https://ton-domaine.vercel.app

# ── Pipeline d'ingestion Ollama ───────────────────────────────────────────────
# Clé secrète protégeant l'endpoint POST /api/ingest.
# Génère avec : openssl rand -hex 32
INGEST_API_KEY=remplace_par_une_cle_secrete
